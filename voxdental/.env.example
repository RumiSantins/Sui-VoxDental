# Configuración de base de datos y JWT
SECRET_KEY=vox-dental-secret-key-development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=360

# Configuración de Correo (SMTP)
# Para Gmail: usar Contraseña de Aplicación. Para Mailtrap, copiar host/port de su panel.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-contraseña-de-aplicación

# URL de la aplicación Frontend (para los enlaces de los correos)
BASE_URL=http://localhost:5173
